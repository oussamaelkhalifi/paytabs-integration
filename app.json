{
  "expo": {
    "name": "nestpro",
    "slug": "nestpro",
    "version": "1.2.8",
    "orientation": "portrait",
    "icon": "./assets/images/nestpro_icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.nestpro.mobile",
      "config": {
        "googleMapsApiKey": ""
      },
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to the camera to take property photos.",
        "NSPhotoLibraryUsageDescription": "This app needs access to photos for uploading property photos.",
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show your position on the map and locate properties.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to your location to show your position on the map and locate properties.",
        "CFBundleAllowMixedLocalizations": true,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSContactsUsageDescription": "Cette application a besoin d'accéder à vos contacts pour vous permettre de les inviter."
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "newArchEnabled": false,
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      },
      "package": "app.nestpro.mobile",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Aloevera-Black.otf",
            "./assets/fonts/Aloevera-Bold.otf",
            "./assets/fonts/Aloevera-ExtraBold.otf",
            "./assets/fonts/Aloevera-ExtraLight.otf",
            "./assets/fonts/Aloevera-Light.otf",
            "./assets/fonts/Aloevera-Medium.otf",
            "./assets/fonts/Aloevera-Regular.otf",
            "./assets/fonts/Aloevera-SemiBold.otf",
            "./assets/fonts/Aloevera-Thin.otf",
            "./assets/fonts/Figtree.ttf"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you upload property photos.",
          "cameraPermission": "The app accesses your camera to let you take property photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/images/pins/property_pin.png",
            "./assets/images/pins/property_pin_available.png",
            "./assets/images/pins/property_pin_unavailable.png"
          ]
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Allow $(PRODUCT_NAME) to access your contacts."
        }
      ],
      [
        "react-native-share",
        {
          "ios": ["fb", "instagram", "twitter", "tiktoksharesdk"],
          "android": [
            "com.facebook.katana",
            "com.instagram.android",
            "com.twitter.android",
            "com.zhiliaoapp.musically"
          ],
          "enableBase64ShareAndroid": true
        }
      ],
      "expo-build-properties",
      "./plugins/withPickFirstSo",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "aa5ca221-a4c6-4b79-b1a4-5622f2a0f09e"
      }
    },
    "owner": "o.elkhalifi"
  }
}
